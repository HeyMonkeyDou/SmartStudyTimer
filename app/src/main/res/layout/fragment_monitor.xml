<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="48dp"
    android:gravity="top|center_horizontal">

    <!-- Title -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Focus Monitor"
        android:textSize="26sp"
        android:textStyle="bold"
        android:layout_marginBottom="32dp"/>

    <!-- Statistics -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:layout_marginBottom="32dp">

        <TextView
            android:id="@+id/tvDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Today:"
            android:textStyle="bold"
            android:layout_marginBottom="32dp"/>

        <TextView
            android:id="@+id/tvStars"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⭐⭐⭐⭐⭐"
            android:textSize="32sp"
            android:textStyle="bold"
            android:layout_marginBottom="32dp"/>

        <TextView
            android:id="@+id/tvFocusLevel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Focus Level:"
            android:textSize="26sp"
            android:textStyle="bold"
            android:layout_marginBottom="32dp"/>

    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:layout_marginBottom="32dp">

        <TextView
            android:id="@+id/tvSessionTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Session Time:"
            android:layout_marginBottom="32dp"/>

        <TextView
            android:id="@+id/tvInterruptedCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Interrupted Count:"
            android:layout_marginBottom="32dp"/>

        <TextView
            android:id="@+id/tvPickupCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Pickup Count:"
            android:layout_marginBottom="32dp"/>

        <TextView
            android:id="@+id/tvPhoneUseCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Phone-use Count:"
            android:layout_marginBottom="32dp"/>

    </LinearLayout>

</LinearLayout>